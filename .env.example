# Kopiere diese Datei nach `.env` und trage deine Werte ein.
# Die App liest `.env` beim Start aus dem Projekt-Root (Dev) oder dem Ordner
# neben `companion.exe` (Production).

# Pflicht: dein Anthropic-API-Key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: dein Standort, damit die Katze Wetterfragen ohne Rückfrage
# beantworten kann.
USER_LOCATION=Lüneburg, Germany

# Optional: iCloud Kalender. Beide Felder müssen gesetzt sein damit die
# Katze "was steht heute an" beantworten kann.
#
# 1. Apple-ID, mit der iCloud aktiviert ist.
# 2. App-spezifisches Passwort (KEIN normales Apple-Passwort).
#    Erstellen unter https://appleid.apple.com → Anmeldung & Sicherheit →
#    App-spezifische Passwörter → Passwort generieren → "Companion" benennen.
ICLOUD_USERNAME=
ICLOUD_APP_PASSWORD=

# Optional: nur diese Kalender abfragen (Komma-getrennt). Wenn leer → alle
# iCloud-Kalender werden gequeryt. Jeder Eintrag matcht *entweder*:
#   - als Anzeigename-Präfix (case-insensitive), oder
#   - als Substring der URL (z.B. die UUID)
# Bei Dubletten / Namen mit Emojis / `&amp;`-Encoding-Issues lieber UUIDs nehmen
# — die siehst du im Debug-Overlay (Rechtsklick auf Katze → Calendars).
ICLOUD_CALENDARS=

# Optional: Default-Kalender für create_calendar_event wenn Claude keinen
# expliziten Kalender mitgibt. Match wie bei ICLOUD_CALENDARS (Name oder UUID).
ICLOUD_DEFAULT_WRITE_CALENDAR=

# Optional: nur diese Erinnerungs-Listen (VTODO) abfragen / beschreiben lassen.
# Selbe Match-Logik wie ICLOUD_CALENDARS (Name-Präfix oder URL-Substring).
# Leer = alle VTODO-Listen auf dem iCloud-Account werden gequeryt.
# Beispiel: ICLOUD_REMINDER_LISTS=D&S ⚠️,<UUID-deiner-Solo-Liste>
ICLOUD_REMINDER_LISTS=

# Optional: Default-Reminder-Liste für create_reminder wenn Claude keine
# Liste mitgibt. Match wie oben.
ICLOUD_DEFAULT_WRITE_REMINDER_LIST=

# Optional: zusätzliche iCal-Feeds, z. B. Google-Kalender die du in der
# iCloud-Calendar-App per URL abonniert hast. Solche Abos liegen nicht auf
# iCloud's Servern (CalDAV findet sie nicht) — wir holen sie direkt von der
# Quelle.
#
# Komma- oder Zeilenumbruch-getrennt. webcal:// wird automatisch zu https://.
# Für Google: Calendar → Settings → Calendar wählen → "Integrate calendar" →
# "Secret address in iCal format" (oder "Public address" bei geteilten Cals).
EXTRA_ICAL_URLS=

# Optional: IMAP-Zugang (Ionos oder anderer IMAPS-Server) damit Fibi
# Mails lesen kann. Read-only — keine Schreib-Aktionen via Tool.
# Bei Ionos: imap.ionos.de auf Port 993 (TLS implizit).
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Optional: SMTP-Versand. Default-Verhalten: nutzt IMAP_USERNAME +
# IMAP_PASSWORD, SMTP_HOST wird aus IMAP_HOST abgeleitet ('imap.' → 'smtp.').
# Nur setzen wenn dein Mail-Provider getrennte Hosts/Credentials braucht.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=
