{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Companion",
  "version": "0.1.0",
  "identifier": "com.david.companion",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "cat",
        "url": "cat/index.html",
        "title": "Companion",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false,
        "width": 1920,
        "height": 540,
        "x": 0,
        "y": 0
      },
      {
        "label": "settings",
        "url": "settings/index.html",
        "title": "Fibi · Einstellungen",
        "width": 600,
        "height": 360,
        "resizable": false,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.anthropic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../bridge/pyicloud/*.py": "bridge/pyicloud/",
      "../bridge/models/fibi.onnx": "bridge/models/fibi.onnx",
      "../bridge/models/ggml-small.bin": "bridge/models/ggml-small.bin",
      "../bridge/setup.ps1": "bridge/setup.ps1",
      "../.env.example": ".env.example"
    }
  },
  "plugins": {}
}
